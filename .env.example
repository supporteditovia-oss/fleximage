# App
NODE_ENV=development
PORT=5000
# Local only — production always uses https://www.luxeflexia.com
APP_URL=http://localhost:5000
# Public site URL for robots.txt / sitemap.xml / Stripe / OAuth fallbacks
SITE_URL=https://www.luxeflexia.com
LOG_LEVEL=info
# Optional: force auth redirect origin (otherwise window.location.origin is used)
# VITE_PUBLIC_APP_URL=https://www.luxeflexia.com
#
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://www.luxeflexia.com (prod) — do NOT leave localhost or Replit
#   Redirect URLs (required for Google OAuth):
#     http://localhost:5000/**
#     http://127.0.0.1:5000/**
#     https://www.luxeflexia.com/**
#     https://luxeflexia.com/**
# Google Cloud → OAuth 2.0 Client:
#   Authorized JavaScript origins: http://localhost:5000 , https://www.luxeflexia.com , https://luxeflexia.com
#   Authorized redirect URIs: https://<project-ref>.supabase.co/auth/v1/callback

# Supabase
# Public browser key. Safe to expose to the client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only key. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
# Use a REAL secret key from Stripe Dashboard → Developers → API keys
# Must match price mode: sk_test_... with test prices, sk_live_... with live prices
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_WEBHOOK_ENDPOINT_ID=
STRIPE_WEBHOOK_URL=https://your-domain.example.com/api/stripe/webhook
# Live monthly plans (EUR) — keep mapped 1:1 with server/lib/stripe.ts credits
# Découverte 8,90€ → 250 crédits/mois
STRIPE_DISCOVERY_PRICE_ID=price_1TuYXR46E9Di7XBgxmpSdu7s
# Essentiel 19,90€ → 850 + 250 offerts = 1100 crédits/mois
STRIPE_ESSENTIAL_PRICE_ID=price_1TuYcG46E9Di7XBgdktOd6cg
# Ultimate 39,90€ → 2500 crédits/mois
STRIPE_ULTIMATE_PRICE_ID=price_1TuYdI46E9Di7XBg8wLEuogs

# Stripe legacy / fallback price ids
# Keep empty unless you need compatibility with old plans.
STRIPE_PRICE_ID=
STRIPE_IMAGE_PRICE_ID=
STRIPE_VIDEO_PRICE_ID=
STRIPE_WEEKLY_PRICE_ID=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_WEEKLY_LEGACY_PRICE_IDS=
STRIPE_MONTHLY_LEGACY_PRICE_IDS=
STRIPE_IMAGE_LEGACY_PRICE_IDS=
STRIPE_VIDEO_LEGACY_PRICE_IDS=

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-public-r2-domain.example.com

# AI providers
KIE_AI_API_KEY=your_kie_ai_api_key
ONESHOT_API_URL=
ONESHOT_API_KEY=

# Snap Pixel / Conversions API
# Browser pixel (Vite public). Leave empty until Ads Manager pixel is ready.
VITE_SNAP_PIXEL_ID=
# Server-side CAPI (PURCHASE from Stripe webhook only). Never expose the token.
SNAP_PIXEL_ID=
SNAP_CAPI_TOKEN=
