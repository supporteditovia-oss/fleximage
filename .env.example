# App
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
LOG_LEVEL=info

# Supabase
# Public browser key. Safe to expose to the client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only key. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_WEEKLY_PRICE_ID=price_your_weekly_plan
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_plan

# Stripe legacy / fallback price ids
# Keep empty unless you need compatibility with old plans.
STRIPE_PRICE_ID=
STRIPE_IMAGE_PRICE_ID=
STRIPE_VIDEO_PRICE_ID=
STRIPE_WEEKLY_LEGACY_PRICE_IDS=
STRIPE_MONTHLY_LEGACY_PRICE_IDS=
STRIPE_IMAGE_LEGACY_PRICE_IDS=
STRIPE_VIDEO_LEGACY_PRICE_IDS=

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-public-r2-domain.example.com

# AI providers
KIE_AI_API_KEY=your_kie_ai_api_key
ONESHOT_API_URL=
ONESHOT_API_KEY=
