{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/((?!api/|assets/|cgu(?:/.*)?$|confidentialite(?:/.*)?$).*)",
      "destination": "/index.html"
    }
  ]
}
